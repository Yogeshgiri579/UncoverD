# ─── Database ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
PORT=5000

# ─── Admin Credentials (used for first-time / env-based admin login) ──────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace_with_secure_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ─── CORS (comma-separated list of allowed frontend origins) ──────────────
# Leave blank or omit for local dev (localhost 3000/5173/5174 auto-allowed)
ALLOWED_ORIGINS=https://your-frontend.onrender.com,https://your-admin.onrender.com

# ─── Payment (PayU) ───────────────────────────────────────────────────────
PAYU_KEY=your_payu_key
PAYU_SALT=your_payu_salt
PAYU_BASE_URL=https://sandbox.payu.in
PAYU_SUCCESS_URL=https://your-frontend.onrender.com/payment-success
PAYU_FAILURE_URL=https://your-frontend.onrender.com/payment-failure

# ─── Shipping (Shiprocket) ────────────────────────────────────────────────
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
